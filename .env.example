# --- BOT CONFIG ---
BOT_TOKEN=your_telegram_bot_token
ENCRYPTION_KEY=your_32_character_key_for_aes
DATABASE_URL="postgresql://user:pass@host:5432/db"
JUPITER_API_KEY=your_jupiter_api_key
GROQ_API_KEY=your_groq_api_key

# --- RPC CONFIGURATION ---
NETWORK_TYPE=devnet # 'mainnet' or 'devnet'

# Solana
SOLANA_MAINNET_RPC=https://solana-mainnet.g.alchemy.com/v2/your_key
SOLANA_DEVNET_RPC=https://api.devnet.solana.com

# Ethereum
ETH_MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/your_key
ETH_DEVNET_RPC=https://rpc2.sepolia.org

# Base
BASE_MAINNET_RPC=https://base-mainnet.g.alchemy.com/v2/your_key
BASE_DEVNET_RPC=https://sepolia.base.org

# --- REVENUE / FEE CONFIGURATION ---
TREASURY_SOL_ADDRESS=your_solana_treasury_address
TREASURY_EVM_ADDRESS=your_evm_treasury_address
FEE_PERCENTAGE=0.01 # 1% convenience fee

# --- IPFS (Pinata) ---
PINATA_API_KEY=your_pinata_key
PINATA_SECRET_KEY=your_pinata_secret
