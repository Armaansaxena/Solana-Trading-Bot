{
  "name": "solana-trading-bot",
  "version": "1.0.0",
  "description": "Telegram bot for Solana wallet management",
  "main": "index.ts",
  "scripts": {
    "start": "npx tsx src/index.ts",
    "dev": "npx tsx watch src/index.ts",
    "dev:local": "dotenv -e .env.local npx tsx watch src/index.ts",
    "build": "tsc",
    "generate-key": "node -e \"console.log('ENCRYPTION_KEY=' + require('crypto').randomBytes(32).toString('hex'))\""
  },
  "keywords": [
    "solana",
    "telegram",
    "bot",
    "crypto"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@jup-ag/api": "^6.0.48",
    "@metaplex-foundation/mpl-token-metadata": "^2.13.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@metaplex-foundation/umi-web3js-adapters": "^1.5.1",
    "@pinata/sdk": "^2.1.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.95.8",
    "@upstash/redis": "^1.36.1",
    "bs58": "^5.0.0",
    "dotenv": "^17.2.3",
    "groq-sdk": "^1.1.1",
    "pg": "^8.20.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.18.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
