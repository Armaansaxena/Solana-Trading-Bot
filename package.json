{
  "name": "solana-trading-bot",
  "version": "1.0.0",
  "description": "Telegram bot for Solana wallet management",
  "main": "index.ts",
  "scripts": {
    "start": "ts-node index.ts",
    "dev": "ts-node-dev --respawn index.ts",
    "build": "tsc",
