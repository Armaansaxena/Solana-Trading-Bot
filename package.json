    "@upstash/redis": "^1.36.1",
    "bs58": "^5.0.0",
    "dotenv": "^17.2.3",
    "pg": "^8.17.2",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/pg": "^8.16.0",
    "prisma": "6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
