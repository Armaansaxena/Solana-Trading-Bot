
generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int      @id @default(autoincrement())
  telegramId      BigInt   @unique
  activeWalletId  Int?
  activeChain     String   @default("solana")
  createdAt       DateTime @default(now())

  wallets         Wallet[]
  activeWallet    Wallet?  @relation("ActiveWallet", fields: [activeWalletId], references: [id], onDelete: SetNull)

  // Keep for migration, will drop later
  publicKey       String?
  encryptedKey    String?
  iv              String?
}

model Wallet {
  id           Int      @id @default(autoincrement())
  userId       Int
  name         String   @default("Main Wallet")
  publicKey    String   @unique
  encryptedKey String
  iv           String
  chain        String   @default("solana")
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeUsers  User[]   @relation("ActiveWallet")
}

model transaction {
  id          Int       @id @default(autoincrement())
  telegramId  BigInt
  type        String
  fromToken   String?
  toToken     String?
  amount      Float
  signature   String
  status      String
  createdAt   DateTime  @default(now())
}

model Alert {
  id         Int      @id @default(autoincrement())
  telegramId BigInt
  token      String
  targetPrice Float
  condition  String   // "above" or "below"
  triggered  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Watchlist {
  id         Int      @id @default(autoincrement())
  telegramId BigInt
  token      String
  mintAddress String?
  createdAt  DateTime @default(now())

  @@unique([telegramId, token])
}

model Referral {
  id           Int      @id @default(autoincrement())
  referrerId   BigInt
  referredId   BigInt   @unique
  createdAt    DateTime @default(now())
}
