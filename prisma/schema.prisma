datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  engineType    = "binary"
}

model User {
  id           Int      @id @default(autoincrement())
  telegramId   BigInt   @unique
  publicKey    String
  encryptedKey String
  iv           String
  createdAt    DateTime @default(now())
}