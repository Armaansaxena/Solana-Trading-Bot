
generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  telegramId   BigInt   @unique
  publicKey    String
  encryptedKey String
  iv           String
  createdAt    DateTime @default(now())
}